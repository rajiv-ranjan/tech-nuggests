# OpenShift User Management Configuration

# Path to the oc CLI binary
# Default: /usr/local/bin/oc
# Common locations:
#   - macOS (Homebrew): /usr/local/bin/oc or /opt/homebrew/bin/oc
#   - Linux: /usr/local/bin/oc or /usr/bin/oc
#   - Custom install: /path/to/your/oc
OC_CLI_PATH=/usr/local/bin/oc

# You can find your oc path by running: which oc
